WCreateConnection<- CCreateConnection[::ip,port,isServer:socket_id]
short.german
  Create network connection.;
  
short.english
  Create network connection.;

module
  foundation;

chapter.german
  BenutzerErweiterungen;

chapter.english
  UserExtensions;

keywords.english
  UserExtensions, Network, Socket, Connection;

parallelization
  process_exclusively: false;
  process_locally:     false;
  process_mutual:      false;
  method:              none;

parameter
  ip:                 input_control;
  default_type:       string;
  multivalue:         false;
  sem_type:           string;
  type_list:          string;

parameter
  port:               input_control;
  default_type:       integer;
  multivalue:         false;
  sem_type:           number;
  type_list:          integer;

parameter
  isServer:           input_control;
  default_type:       integer;
  multivalue:         false;
  sem_type:           number;
  type_list:          integer;

parameter
  socket_id:          output_control;
  default_type:       integer;
  multivalue:         false;
  sem_type:           number;
  type_list:          integer;


